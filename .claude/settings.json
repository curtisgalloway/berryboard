{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.claude/hooks/validate-kicad.sh\"",
            "timeout": 60,
            "statusMessage": "Validating KiCad files..."
          }
        ]
      }
    ]
  }
}
